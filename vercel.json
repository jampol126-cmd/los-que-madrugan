{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/envio-masivo", "schedule": "30 10 * * *" },
    { "path": "/api/resumen-admin", "schedule": "0 23 * * *" },
    { "path": "/api/limpieza-inactivos", "schedule": "0 8 1 * *" }
  ]
}
